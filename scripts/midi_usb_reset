#!/bin/bash
# Bash script to enable or disable automatic USB MIDI reset at system boot

SERVICE_NAME="depinus-usb-reset"
SERVICE_FILE="/etc/systemd/system/$SERVICE_NAME.service"

if [ "$EUID" -ne 0 ]; then
    echo "Please run this script as root (e.g., using sudo)."
    exit 1
fi

if [ -z "$1" ]; then
    echo "Usage: $0 enable | disable"
    echo ""
    echo "This script configures automatic USB MIDI hotplug fix at system boot."
    echo "This may fix Linux/ALSA initialization issues when USB MIDI devices are"
    echo "connected during boot. Boot initialization causes timing jitter, while"
    echo "hotplug initialization works correctly. This service forces hotplug-style"
    echo "re-initialization by unbinding and re-binding the USB device."
    echo ""
    echo "  enable  - Create systemd service to apply USB MIDI hotplug fix at boot"
    echo "  disable - Remove systemd service"
    exit 1
fi

if [ "$1" == "enable" ]; then
    echo "Enabling automatic USB MIDI reset at boot..."
    cat > "$SERVICE_FILE" <<'EOL'
[Unit]
Description=Depinus USB MIDI Hotplug Fix (unbind/bind)
After=multi-user.target
Wants=multi-user.target

[Service]
Type=oneshot
ExecStart=/bin/bash -c '\
    # Wait until system is fully initialized (PipeWire, ALSA, udev)
    sleep 12; \
    echo "Searching for USB MIDI devices..."; \
    DEVICE_FOUND=0; \
    for dev in /sys/bus/usb/devices/*/product; do \
        if grep -Eqi "midi" "$dev" 2>/dev/null; then \
            DEVICE_DIR=$(dirname "$dev"); \
            DEVICE_ID=$(basename "$DEVICE_DIR"); \
            echo "Found USB MIDI device: $(cat "$dev") at $DEVICE_DIR"; \
            echo "Performing USB driver unbind/bind reset on $DEVICE_ID..."; \
            echo -n "$DEVICE_ID" > /sys/bus/usb/drivers/usb/unbind; \
            sleep 3; \
            echo -n "$DEVICE_ID" > /sys/bus/usb/drivers/usb/bind; \
            echo "USB MIDI device reset complete"; \
            DEVICE_FOUND=1; \
        fi; \
    done; \
    if [ $DEVICE_FOUND -eq 0 ]; then \
        echo "No USB MIDI device found at boot (may be plugged in later)"; \
    fi'
RemainAfterExit=yes
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
EOL

    # Reload systemd and enable service
    systemctl daemon-reload
    systemctl enable "$SERVICE_NAME"

    echo "Automatic USB MIDI hotplug fix enabled successfully."
    echo ""
    echo "Service created at: $SERVICE_FILE"
    echo "The USB MIDI device will be re-initialized automatically on every boot."
    echo "This forces hotplug-style initialization to fix ALSA timing issues."
    echo ""
    echo "To test now: sudo systemctl start $SERVICE_NAME"
    echo "View logs:   sudo journalctl -u $SERVICE_NAME"
    echo "To disable:  sudo $0 disable"
    exit 0
fi

if [ "$1" == "disable" ]; then
    echo "Disabling automatic USB MIDI hotplug fix..."

    if [ -f "$SERVICE_FILE" ]; then
        systemctl stop "$SERVICE_NAME" 2>/dev/null
        systemctl disable "$SERVICE_NAME"
        rm "$SERVICE_FILE"
        systemctl daemon-reload
        echo "Automatic USB MIDI hotplug fix disabled."
        echo "Service removed from $SERVICE_FILE"
    else
        echo "Automatic USB MIDI hotplug fix is not enabled."
    fi
    exit 0
fi

echo "Usage: $0 enable | disable"
exit 1
