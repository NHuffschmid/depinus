#!/bin/bash
# Bash script to enable or disable automatic USB MIDI reset at system boot

SERVICE_NAME="depinus-usb-reset"
SERVICE_FILE="/etc/systemd/system/$SERVICE_NAME.service"

if [ "$EUID" -ne 0 ]; then
    echo "Please run this script as root (e.g., using sudo)."
    exit 1
fi

if [ -z "$1" ]; then
    echo "Usage: $0 enable | disable"
    echo ""
    echo "This script configures automatic USB MIDI hotplug fix at system boot."
    echo "This fixes Linux/ALSA initialization issues when USB MIDI devices are"
    echo "connected during boot. Boot initialization causes timing jitter, while"
    echo "hotplug initialization works correctly. This service forces hotplug-style"
    echo "re-initialization by deauthorizing and re-authorizing the USB device."
    echo ""
    echo "  enable  - Create systemd service to apply USB MIDI hotplug fix at boot"
    echo "  disable - Remove systemd service"
    exit 1
fi

if [ "$1" == "enable" ]; then
    echo "Enabling automatic USB MIDI reset at boot..."
    
    # Create systemd service with inline reset script
    # This service fixes ALSA timing issues when USB MIDI devices are connected during boot.
    # The kernel/ALSA initialization at boot is flawed for some USB MIDI interfaces,
    # resulting in massive jitter and chaotic MIDI timing. Hotplug initialization works correctly.
    # This service forces a hotplug-style re-initialization by deauthorizing and re-authorizing
    # the USB device, which triggers clean ALSA initialization and stable MIDI timing.
    cat > "$SERVICE_FILE" <<'EOL'
[Unit]
Description=Depinus USB MIDI Hotplug Fix Service
Before=network.target
DefaultDependencies=no

[Service]
Type=oneshot
ExecStart=/bin/bash -c '\
    echo "Searching for USB MIDI device..."; \
    DEVICE_FOUND=0; \
    for dev in /sys/bus/usb/devices/*/product; do \
        if grep -qi "midi" "$dev" 2>/dev/null; then \
            DEVICE_DIR=$(dirname "$dev"); \
            DEVICE_NAME=$(cat "$dev" 2>/dev/null); \
            DEVICE_ID=$(basename "$DEVICE_DIR"); \
            AUTHORIZED_FILE="$DEVICE_DIR/authorized"; \
            if [ ! -f "$AUTHORIZED_FILE" ]; then \
                echo "Warning: No authorized file found for $DEVICE_ID, skipping"; \
                continue; \
            fi; \
            echo "Found USB MIDI device: $DEVICE_NAME at $DEVICE_DIR"; \
            echo "Forcing hotplug re-initialization for device $DEVICE_ID..."; \
            echo "0" > "$AUTHORIZED_FILE" 2>/dev/null || true; \
            sleep 1; \
            echo "1" > "$AUTHORIZED_FILE" 2>/dev/null || true; \
            echo "USB MIDI device hotplug fix applied successfully"; \
            DEVICE_FOUND=1; \
        fi; \
    done; \
    if [ $DEVICE_FOUND -eq 0 ]; then \
        echo "Info: No USB MIDI device found (may be added later via hotplug)"; \
    fi'
RemainAfterExit=yes
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
EOL
    
    # Reload systemd and enable service
    systemctl daemon-reload
    systemctl enable "$SERVICE_NAME"
    
    echo "Automatic USB MIDI hotplug fix enabled successfully."
    echo ""
    echo "Service created at: $SERVICE_FILE"
    echo "The USB MIDI device will be re-initialized automatically on every boot."
    echo "This forces hotplug-style initialization to fix ALSA timing issues."
    echo ""
    echo "To test now: sudo systemctl start $SERVICE_NAME"
    echo "View logs:   sudo journalctl -u $SERVICE_NAME"
    echo "To disable:  sudo $0 disable"
    exit 0
fi

if [ "$1" == "disable" ]; then
    echo "Disabling automatic USB MIDI hotplug fix..."
    
    if [ -f "$SERVICE_FILE" ]; then
        systemctl stop "$SERVICE_NAME" 2>/dev/null
        systemctl disable "$SERVICE_NAME"
        rm "$SERVICE_FILE"
        systemctl daemon-reload
        echo "Automatic USB MIDI hotplug fix disabled."
        echo "Service removed from $SERVICE_FILE"
    else
        echo "Automatic USB MIDI hotplug fix is not enabled."
    fi
    exit 0
fi

echo "Usage: $0 enable | disable"
exit 1
