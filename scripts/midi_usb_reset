#!/bin/bash
# Bash script to enable or disable the USB MIDI Reset Daemon on Linux machines

DAEMON_PATH="$(dirname "$(readlink -f "$0")")/midi_usb_reset_daemon.sh"
SERVICE_NAME="depinus-usb-reset-daemon"
SERVICE_FILE="/etc/systemd/system/$SERVICE_NAME.service"
DEFAULT_PORT=1732

if [ "$EUID" -ne 0 ]; then
    echo "Please run this script as root (e.g., using sudo)."
    exit 1
fi

if [ -z "$1" ]; then
    echo "Usage: $0 enable [port] | disable"
    echo ""
    echo "This script configures the USB MIDI Reset Daemon that runs with root privileges."
    echo "The daemon listens for reset triggers from the piano daemon and performs USB device"
    echo "resets to fix ALSA timing issues on Linux systems."
    echo ""
    echo "  enable [port] - Create and start systemd service (default port: $DEFAULT_PORT)"
    echo "  disable       - Stop and remove systemd service"
    exit 1
fi

if [ "$1" == "enable" ]; then
    PORT=${2:-$DEFAULT_PORT}
    
    echo "Enabling USB MIDI Reset Daemon on port $PORT..."
    
    # Validate port number
    if ! [[ "$PORT" =~ ^[0-9]+$ ]] || [ "$PORT" -lt 1024 ] || [ "$PORT" -gt 65535 ]; then
        echo "Error: Port must be a number between 1024 and 65535"
        exit 1
    fi
    
    # Check if daemon script exists
    if [ ! -f "$DAEMON_PATH" ]; then
        echo "Error: Daemon script not found at $DAEMON_PATH"
        exit 1
    fi
    
    # Create systemd service
    cat > "$SERVICE_FILE" <<EOL
[Unit]
Description=Depinus USB MIDI Reset Daemon
After=network.target
Before=depinus-headless.service

[Service]
Type=simple
ExecStart=$DAEMON_PATH $PORT
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
EOL
    
    # Reload systemd and enable service
    systemctl daemon-reload
    systemctl enable "$SERVICE_NAME"
    systemctl start "$SERVICE_NAME"
    
    echo "USB MIDI Reset Daemon enabled successfully on port $PORT."
    echo ""
    echo "Service created at: $SERVICE_FILE"
    echo "The daemon will start automatically on system boot."
    echo ""
    echo "To check status: sudo systemctl status $SERVICE_NAME"
    echo "View logs:       sudo journalctl -u $SERVICE_NAME -f"
    echo "To disable:      sudo $0 disable"
    exit 0
fi

if [ "$1" == "disable" ]; then
    echo "Disabling USB MIDI Reset Daemon..."
    
    if [ -f "$SERVICE_FILE" ]; then
        systemctl stop "$SERVICE_NAME" 2>/dev/null
        systemctl disable "$SERVICE_NAME"
        rm "$SERVICE_FILE"
        systemctl daemon-reload
        echo "USB MIDI Reset Daemon disabled."
        echo "Service removed from $SERVICE_FILE"
    else
        echo "USB MIDI Reset Daemon is not enabled."
    fi
    exit 0
fi

echo "Usage: $0 enable [port] | disable"
exit 1
