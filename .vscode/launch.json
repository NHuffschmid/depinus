{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "PowerShell",
            "request": "launch",
            "name": "PowerShell Launch (current file)",
            "script": "${file}",
            "args": [],
            "cwd": "${file}"
        },
        {
            "type": "PowerShell",
            "request": "launch",
            "name": "Build Windows installer",
            "script": "${workspaceFolder}/develop/installer/windows/build.ps1",
            "args": [],
            "cwd": "${workspaceFolder}/develop/installer/windows"
        },
        {
            "name": "Frontend launcher",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}/www/client",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "dev"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "Backend launcher",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}/www/server",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "start"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "Backend Test launcher",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}/www/server",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "test"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "PianoDaemon launcher",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/python/depinus/piano_daemon.py",
            "console": "integratedTerminal"
        },
        {
            "name": "Launch Chrome against Vite dev server",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}/www/client/src",
            "sourceMaps": true,
            "trace": true
        }
    ],
    "compounds": [
        {
            "name": "Windows DEV environment",
            "configurations": [
                "PianoDaemon launcher",
                "Backend launcher",
                "Frontend launcher",
                "Launch Chrome against Vite dev server"
            ],
            "stopAll": true
        },
    ]
}